{
  "name": "zettlab-sync",
  "version": "0.1.0",
  "description": "WebDAV-only sync for Zettlab NAS and Obsidian.",
  "scripts": {
    "dev": "node esbuild.config.mjs --watch",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "format": "npx @biomejs/biome check --write .",
    "clean": "npx rimraf main.js",
    "test": "mocha --import=tsx 'tests/zettlab/**/*.test.ts'"
  },
  "browser": {
    "path": "path-browserify",
    "process": "process/browser"
  },
  "keywords": [],
  "author": "Zettlab",
  "license": "Apache-2.0",
  "devDependencies": {
    "@biomejs/biome": "1.8.3",
    "@types/lodash": "^4.17.7",
    "@types/mocha": "^10.0.7",
    "@types/node": "^20.14.12",
    "esbuild": "^0.23.0",
    "mocha": "^10.7.0",
    "obsidian": "^1.5.7",
    "rimraf": "^6.0.1",
    "tslib": "^2.6.3",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4",
    "webdav-server": "^2.6.2"
  },
  "dependencies": {
    "@fyears/tsqueue": "^1.0.1",
    "buffer": "^6.0.3",
    "emoji-regex": "^10.3.0",
    "http-status-codes": "^2.3.0",
    "localforage": "^1.10.0",
    "localforage-getitems": "^1.4.2",
    "localforage-removeitems": "^1.4.0",
    "lodash": "^4.17.21",
    "nanoid": "^5.0.7",
    "path-browserify": "^1.0.1",
    "process": "^0.11.10",
    "rfc4648": "^1.5.3",
    "webdav": "^5.6.0",
    "xregexp": "^5.1.1"
  }
}
